source "https://rubygems.org"

# Keep local preview aligned with the core versions used by GitHub Pages,
# without installing its full collection of optional plugins.
gem "jekyll", "3.10.0"
gem "jekyll-sass-converter", "1.5.2"
gem "kramdown-parser-gfm", "1.1.0"
gem "minima", "2.5.1"
gem "jekyll-seo-tag", "2.8.0"

# Ruby 3+ no longer bundles a default HTTP server.
gem "webrick", "~> 1.9"

# Windows does not provide the IANA timezone database to Ruby.
gem "tzinfo-data"
